{
  "name": "kevinyank.com",
  "version": "1.0.0",
  "description": "Kevin Yank's personal website",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:postcss && npm run build:eleventy",
    "build:eleventy": "eleventy",
    "build:postcss": "postcss styles/styles.css --dir _tmp",
    "clean": "rm -rf _site _tmp",
    "debug": "eleventy",
    "start": "npm run start:eleventy & npm run start:postcss",
    "start:eleventy": "eleventy --serve --incremental",
    "start:postcss": "postcss styles/styles.css --dir _tmp --watch --verbose",
    "test": "node --test _tests/*.test.mjs",
    "test:visual": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentience/kevinyank.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "homepage": "https://kevinyank.com/",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@chromatic-com/playwright": "^0.14.10",
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@shopify/prettier-plugin-liquid": "^1.10.3",
    "@tailwindcss/postcss": "^4.3.2",
    "chromatic": "^18.0.1",
    "eleventy-plugin-time-to-read": "^1.3.0",
    "fast-xml-parser": "^5.9.3",
    "highlight.js": "^11.11.1",
    "markdown-it-anchor": "^9.2.0",
    "postcss": "^8.5.16",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-logical": "^4.2.0"
  },
  "dependencies": {
    "@slack/webhook": "^7.1.0",
    "ioredis": "^5.11.1",
    "netlify-cli": "^26.1.0",
    "node-fetch": "^3.3.2",
    "pushover-notifications": "^1.2.3"
  }
}
