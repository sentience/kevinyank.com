{
  "name": "kevinyank.com",
  "version": "1.0.0",
  "description": "Kevin Yank's personal website",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:postcss && npm run build:eleventy",
    "build:eleventy": "eleventy",
    "build:postcss": "postcss styles/styles.css --dir _tmp",
    "clean": "rm -rf _site _tmp",
    "debug": "eleventy",
    "start": "npm run start:eleventy & npm run start:postcss",
    "start:eleventy": "eleventy --serve --incremental",
    "start:postcss": "postcss styles/styles.css --dir _tmp --watch --verbose",
    "test": "node --test _tests/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sentience/kevinyank.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "homepage": "https://kevinyank.com/",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@chromatic-com/playwright": "^0.12.8",
    "@netlify/functions": "^5.1.3",
    "@playwright/test": "^1.58.2",
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "@tailwindcss/postcss": "^4.2.1",
    "chromatic": "^15.3.0",
    "eleventy-plugin-time-to-read": "^1.3.0",
    "fast-xml-parser": "^5.5.6",
    "highlight.js": "^11.11.1",
    "markdown-it-anchor": "^9.2.0",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tailwindcss-logical": "^4.2.0"
  },
  "dependencies": {
    "@slack/webhook": "^7.0.3",
    "ioredis": "^5.10.0",
    "netlify-cli": "^24.3.0",
    "node-fetch": "^3.3.2",
    "pushover-notifications": "^1.2.3"
  }
}
